<%- include('partials/head') %>
<%- include('partials/navbar') %>

<section style="padding: 3rem 0; background: #fff; min-height: 60vh;">
  <div class="container">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem;">
      <div>
        <h2 style="font-size: 2rem; font-weight: 900; text-transform: uppercase;">Student Dashboard</h2>
        <p style="color: #555;">Welcome, <%= user.displayName || 'Student' %>! Manage your internships and track your progress.</p>
      </div>
    </div>

    <% if (!enrollments || enrollments.length === 0) { %>
      <div class="card-sharp" style="padding: 3rem; text-align: center; border: 2px solid #000;">
        <h3 style="font-size: 1.4rem; margin-bottom: 1rem;">No Active Internships</h3>
        <p style="color: #555; margin-bottom: 2rem;">You haven't enrolled in any internship program yet. Browse our domains and apply now!</p>
        <a href="/#domains" class="btn-sharp" style="text-decoration: none;">Browse Domains</a>
      </div>
    <% } else { %>
      <div style="display: flex; flex-direction: column; gap: 2rem;">
        <% enrollments.forEach(function(enrollment) { %>
          <div class="card-sharp" style="padding: 2rem; border: 2px solid #000; background: #fff;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem;">
              <div>
                <h3 style="font-size: 1.3rem; font-weight: 800; text-transform: uppercase;"><%= enrollment.domain %></h3>
                <p style="font-size: 0.85rem; color: #555;">
                  Intern ID: <code><%= enrollment.internId %></code> &middot;
                  Duration: <%= enrollment.duration %> &middot;
                  Status: <span style="font-weight: bold; color: <%= enrollment.status === 'Completed' ? '#34A853' : '#FBBC05' %>;"><%= enrollment.status %></span>
                </p>
              </div>
              <span class="badge-sharp" style="background-color: #000; color: #fff;"><%= enrollment.status %></span>
            </div>

            <% if (enrollment.projects && enrollment.projects.length > 0) { %>
              <div style="border-top: 2px solid #e5e5e5; padding-top: 1.5rem;">
                <h4 style="font-size: 0.9rem; font-weight: 800; text-transform: uppercase; margin-bottom: 1rem;">Projects &amp; Submissions</h4>
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                  <% enrollment.projects.forEach(function(project, idx) { %>
                    <% var sub = enrollment.submissions && enrollment.submissions[idx]; %>
                    <div style="border: 2px solid #000; padding: 1.25rem; background: #fafafa;">
                      <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem;">
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                          <span class="badge-sharp">Task <%= idx + 1 %></span>
                          <strong><%= project.title || 'Project ' + (idx + 1) %></strong>
                        </div>
                        <% if (sub && sub.verified) { %>
                          <span style="color: #34A853; font-weight: bold;">✓ Verified</span>
                        <% } else if (sub && sub.submittedAt) { %>
                          <span style="color: #FBBC05; font-weight: bold;">⏳ Pending Review</span>
                        <% } else { %>
                          <span style="color: #888; font-weight: bold;">⬜ Not Submitted</span>
                        <% } %>
                      </div>
                      <p style="font-size: 0.85rem; color: #555; margin-bottom: 0.75rem;"><%= project.description %></p>
                      
                      <% if (sub && sub.verified) { %>
                        <div style="font-size: 0.8rem; color: #34A853;">
                          ✓ Verified on <%= sub.verifiedAt ? new Date(sub.verifiedAt).toLocaleDateString() : '-' %>
                          <% if (sub.feedback) { %><br /><strong>Feedback:</strong> <%= sub.feedback %><% } %>
                        </div>
                      <% } else if (sub && sub.resubmit) { %>
                        <div style="font-size: 0.8rem; color: #EA4335; margin-bottom: 0.5rem;">
                          ✗ Rejected: <%= sub.feedback || 'Please resubmit with improvements.' %>
                        </div>
                        <div class="submission-form" data-enrollment="<%= enrollment.id %>" data-index="<%= idx %>">
                          <textarea class="submission-text" placeholder="Enter your project submission details / URL..." style="width: 100%; padding: 0.75rem; border: 2px solid #000; font-family: inherit; font-size: 0.85rem; margin-bottom: 0.5rem; min-height: 60px;"></textarea>
                          <button class="btn-sharp submit-btn" style="font-size: 0.8rem; padding: 0.5rem 1rem;">Resubmit Project</button>
                        </div>
                      <% } else if (sub && sub.submittedAt && !sub.verified) { %>
                        <div style="font-size: 0.8rem; color: #888;">Submitted on <%= new Date(sub.submittedAt).toLocaleDateString() %></div>
                      <% } else { %>
                        <div class="submission-form" data-enrollment="<%= enrollment.id %>" data-index="<%= idx %>">
                          <textarea class="submission-text" placeholder="Enter your project submission details / URL..." style="width: 100%; padding: 0.75rem; border: 2px solid #000; font-family: inherit; font-size: 0.85rem; margin-bottom: 0.5rem; min-height: 60px;"></textarea>
                          <button class="btn-sharp submit-btn" style="font-size: 0.8rem; padding: 0.5rem 1rem;">Submit Project</button>
                        </div>
                      <% } %>
                    </div>
                  <% }); %>
                </div>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</section>

<script>
document.querySelectorAll('.submission-form').forEach(function(form) {
  const btn = form.querySelector('.submit-btn');
  const textarea = form.querySelector('.submission-text');
  const enrollmentId = form.dataset.enrollment;
  const projectIndex = form.dataset.index;

  btn.addEventListener('click', async function() {
    const text = textarea.value.trim();
    if (!text) { alert('Please enter your submission details.'); return; }
    btn.disabled = true;
    btn.textContent = 'Submitting...';
    try {
      const res = await fetch('/api/enrollments/' + enrollmentId + '/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ projectIndex: parseInt(projectIndex), submissionText: text }),
      });
      const data = await res.json();
      if (data.success) {
        alert('Project submitted successfully!');
        location.reload();
      } else {
        alert('Submission failed: ' + (data.message || 'Unknown error'));
      }
    } catch (err) {
      alert('Error submitting: ' + err.message);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Submit Project';
    }
  });
});
</script>

<%- include('partials/footer') %>
